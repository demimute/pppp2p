{
  "name": "dedup-studio",
  "version": "1.0.1",
  "description": "智能照片去重助手 - 基于 CLIP 视觉嵌入 + 感知哈希",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "build:electron:win": "vite build && electron-builder --win portable --x64",
    "start": "electron .",
    "progress:watchdog": "node scripts/progress-watchdog.js",
    "progress:update": "node scripts/progress-update.js",
    "progress:report": "node scripts/progress-report.js",
    "task:orchestrator": "node scripts/task-orchestrator.js",
    "task:complete": "node scripts/task-complete.js",
    "task:watchdog": "node scripts/task-watchdog.js",
    "test:e2e": "playwright test"
  },
  "build": {
    "appId": "com.dedupstudio.app",
    "productName": "PPPP2P",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.59.1",
    "postcss": "^8.4.35",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
